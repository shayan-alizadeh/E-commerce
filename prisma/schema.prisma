// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum roleType {
  user
  admin
  moderator
}
model users {

  id Int @id @default(autoincrement())
  mobile String @unique
  display_name String
  password String
  role roleType @default(user)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  address addresses[]
  ticket tickets[]
  comment comments[]
  // order orders[]
  book_prod bookmark_product[]
  // bask_itm basket_item[]
  // user_roles user_role[]
  // user_permissions user_permission[]
}

model addresses {

  id Int @id @default(autoincrement())
  user_id Int
  province String
  city String
  address String
  postal_code String @db.Char(10)
  reciver_mobile String @db.Char(11)
  description String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user users @relation(fields: [user_id] , references: [id])
  // order orders[]

}

model tickets {

  id Int @id @default(autoincrement())
  user_id Int
  title String
  subject String
  description String
  reply_id Int?
  user users @relation(fields: [user_id],references: [id])
  parent tickets? @relation("TicketsReply",fields: [reply_id],references: [id])
  replies tickets[] @relation("TicketsReply")

}

model comments {
  id Int @id @default(autoincrement())
  user_id Int
  product_id Int
  text String
  score Int?
  created_at DateTime @default(now())
  user users @relation(fields: [user_id],references: [id])
  product products @relation(fields: [product_id],references: [id])
}

model products {

  id Int @id @default(autoincrement())
  title String
  description String
  price Int
  stock Int
  create_at DateTime @default(now())
  update_at DateTime @updatedAt
  comment comments[]
  prod_cat product_category[]
  book_prod bookmark_product[]
  // bask_itm basket_item[]
  // item order_item[]

}

model product_category {

  product_id Int
  category_id Int
  @@unique([product_id,category_id])
  product products @relation(fields: [product_id],references: [id],onDelete: Cascade)
  category categories @relation(fields: [category_id],references: [id],onDelete: Restrict)

}

model categories {

  id Int @id @default(autoincrement())
  title String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  prod_cat product_category[]

}

model bookmark_product {
  id Int @id @default(autoincrement())
  user_id Int
  product_id Int
  @@unique([user_id,product_id])
  user users @relation(fields: [user_id],references: [id])
  product products @relation(fields: [product_id],references: [id])
}