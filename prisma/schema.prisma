// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum roleType {
  user
  admin
  moderator
}
model users {

  id Int @id @default(autoincrement())
  mobile String @unique
  display_name String
  password String
  role roleType @default(user)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  address addresses[]
  ticket tickets[]
  // order orders[]
  // book_prod bookmark_product[]
  // bask_itm basket_item[]
  // user_roles user_role[]
  // user_permissions user_permission[]
}

model addresses {

  id Int @id @default(autoincrement())
  user_id Int
  province String
  city String
  address String
  postal_code String @db.Char(10)
  reciver_mobile String @db.Char(11)
  description String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user users @relation(fields: [user_id] , references: [id])
  // order orders[]

}

model tickets {

  id Int @id @default(autoincrement())
  user_id Int
  title String
  subject String
  description String
  reply_id Int?
  user users @relation(fields: [user_id],references: [id])
  parent tickets? @relation("TicketsReply",fields: [reply_id],references: [id])
  replies tickets[] @relation("TicketsReply")

}