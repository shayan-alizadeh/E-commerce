// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum roleType {
  user
  admin
  moderator
}
model users {

  id Int @id @default(autoincrement())
  mobile String @unique
  display_name String
  password String
  role roleType @default(user)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  address addresses[]
  ticket tickets[]
  comment comments[]
  order orders[]
  book_prod bookmark_product[]
  bask_itm basket_item[]
  user_roles user_role[]
  user_permissions user_permission[]
}

model addresses {

  id Int @id @default(autoincrement())
  user_id Int
  province String
  city String
  address String
  postal_code String @db.Char(10)
  reciver_mobile String @db.Char(11)
  description String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user users @relation(fields: [user_id] , references: [id])
  order orders[]

}

model tickets {

  id Int @id @default(autoincrement())
  user_id Int
  title String
  subject String
  description String
  reply_id Int?
  user users @relation(fields: [user_id],references: [id])
  parent tickets? @relation("TicketsReply",fields: [reply_id],references: [id])
  replies tickets[] @relation("TicketsReply")

}

model comments {

  id Int @id @default(autoincrement())
  user_id Int
  product_id Int
  text String
  score Int?
  created_at DateTime @default(now())
  user users @relation(fields: [user_id],references: [id])
  product products @relation(fields: [product_id],references: [id])
  
}

model products {

  id Int @id @default(autoincrement())
  title String
  description String
  price Int
  stock Int
  create_at DateTime @default(now())
  update_at DateTime @updatedAt
  comment comments[]
  prod_cat product_category[]
  book_prod bookmark_product[]
  bask_itm basket_item[]
  item order_item[]

}

model product_category {

  product_id Int
  category_id Int
  @@unique([product_id,category_id])
  product products @relation(fields: [product_id],references: [id],onDelete: Cascade)
  category categories @relation(fields: [category_id],references: [id],onDelete: Restrict)

}

model categories {

  id Int @id @default(autoincrement())
  title String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  prod_cat product_category[]

}

model bookmark_product {
  id Int @id @default(autoincrement())
  user_id Int
  product_id Int
  @@unique([user_id,product_id])
  user users @relation(fields: [user_id],references: [id])
  product products @relation(fields: [product_id],references: [id])
}

model basket_item {
  id Int @id @default(autoincrement())
  user_id Int
  product_id Int
  quantity Int
  @@unique([user_id,product_id])
  user users  @relation(fields: [user_id],references: [id])
  product products  @relation(fields: [product_id],references: [id])
}

enum orderStatus {
  pending
  completed
  cancelled
}
model orders {
  id Int @id @default(autoincrement())
  user_id Int
  address_id Int
  status orderStatus @default(pending)
  address String
  totalPrice Int
  discounte_code String? @db.VarChar(255)
  payed_time DateTime?
  track_id   String?   @unique 
  ref_id     String?   @unique 
  created_at DateTime @default(now())
  updated_at DateTime  @updatedAt
  user users  @relation(fields: [user_id],references: [id])
  adddress addresses @relation(fields: [address_id],references: [id])
  item order_item[]
}

model order_item {
  id Int @id @default(autoincrement())
  order_id Int
  product_id Int
  quantity   Int   @default(1) 
  unit_price Int
  order orders @relation(fields: [order_id],references: [id])
  product products  @relation(fields: [product_id],references: [id])
}

model roles {
  id Int @id @default(autoincrement())
  name String @unique // admin , support , warehouse , accounting
  role_permissions role_permission[]
  user_roles user_role[]
}

model permissions {
  id Int @id @default(autoincrement())
  name String @unique // warehouse.create , warehouse.update
  role_permissions role_permission[]
  user_permissions user_permission[]
}

model role_permission {
  role_id Int
  permission_id Int
  role roles @relation(fields: [role_id],references: [id])
  permission permissions @relation(fields: [permission_id],references: [id])
  @@id([role_id,permission_id])
}

model user_role {
  user_id Int
  role_id Int
  user users @relation(fields: [user_id],references: [id])
  role roles @relation(fields: [role_id],references: [id])
  @@id([user_id,role_id])
}

model user_permission {
  user_id Int
  permission_id Int
  user users @relation(fields: [user_id],references: [id])
  permission permissions @relation(fields: [permission_id],references: [id])
  @@id([user_id,permission_id])
}